{
  "manifestVersion": 1,
  "name": "Chase",
  "description": "Storm-chase primary: GPS tactical, risk surface, multi-camera strip, wind + compass, dispatch.",
  "template": "chase",
  "theme": { "name": "storm", "accent": "#ffae00", "background": "#07090c", "foreground": "#e7ecf3" },
  "grid": { "cols": 12, "rowHeightPx": 88, "gapPx": 8 },
  "widgets": [
    {
      "id": "gps-hero",
      "type": "gps_map3d",
      "title": "Position",
      "grid": { "col": 1, "row": 1, "w": 7, "h": 4 },
      "bind": { "source": "local", "sensor": "gps", "refreshMs": 1000 }
    },
    {
      "id": "cam-primary",
      "type": "camera_tile",
      "title": "Primary · NVR ch1",
      "grid": { "col": 8, "row": 1, "w": 5, "h": 2 },
      "bind": { "source": "camera", "vehicleCameraSlug": "nvr-ch1" },
      "props": { "rotate": 0, "objectFit": "cover" }
    },
    {
      "id": "cam-drone",
      "type": "camera_tile",
      "title": "Drone · Mavic Pro",
      "grid": { "col": 8, "row": 3, "w": 5, "h": 2 },
      "bind": { "source": "camera", "vehicleCameraSlug": "mavic" },
      "props": { "rotate": 0, "objectFit": "cover" }
    },
    {
      "id": "risk-map",
      "type": "map_tile",
      "title": "Risk surface",
      "grid": { "col": 1, "row": 5, "w": 5, "h": 3 },
      "bind": { "source": "prism", "lens": "stormfront_risk_surface", "refreshMs": 60000 }
    },
    {
      "id": "outlook",
      "type": "stormfront_outlook",
      "title": "Stormfront · Outlook",
      "grid": { "col": 6, "row": 5, "w": 4, "h": 2 },
      "bind": { "source": "prism", "lens": "stormfront_outlook", "refreshMs": 30000 }
    },
    {
      "id": "wind",
      "type": "wind_vector",
      "title": "Wind",
      "grid": { "col": 10, "row": 5, "w": 2, "h": 2 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 2000 }
    },
    {
      "id": "compass",
      "type": "compass_rose",
      "title": "Heading",
      "grid": { "col": 12, "row": 5, "w": 1, "h": 2 },
      "bind": { "source": "local", "sensor": "gps", "refreshMs": 1000 }
    },
    {
      "id": "weather",
      "type": "weather_tile",
      "title": "Roof env",
      "grid": { "col": 6, "row": 7, "w": 4, "h": 1 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 2000 },
      "props": { "fields": ["temp", "hum", "dew", "gust"] }
    },
    {
      "id": "lightning",
      "type": "adsb_strip",
      "title": "Lightning jumps",
      "grid": { "col": 10, "row": 7, "w": 3, "h": 1 },
      "bind": { "source": "prism", "lens": "stormfront_lightning_jump", "refreshMs": 10000 }
    },
    {
      "id": "cam-strip",
      "type": "camera_strip",
      "title": "Cameras",
      "grid": { "col": 1, "row": 8, "w": 8, "h": 2 },
      "props": {
        "sources": [
          { "slug": "nvr-ch3", "label": "CH3 Wide" },
          { "slug": "nvr-ch5", "label": "CH5", "rotate": 90 },
          { "slug": "nvr-ch6", "label": "CH6", "rotate": 90 },
          { "slug": "nvr-ch8", "label": "CH8" }
        ]
      }
    },
    {
      "id": "speed",
      "type": "speed_hud",
      "title": "Speed",
      "grid": { "col": 9, "row": 8, "w": 2, "h": 2 },
      "bind": { "source": "local", "sensor": "gps", "refreshMs": 500 },
      "props": { "unit": "kph" }
    },
    {
      "id": "signal",
      "type": "signal_bar",
      "title": "Uplinks",
      "grid": { "col": 11, "row": 8, "w": 2, "h": 1 }
    },
    {
      "id": "system",
      "type": "system_stats",
      "title": "Host",
      "grid": { "col": 11, "row": 9, "w": 2, "h": 1 }
    },
    {
      "id": "starlink",
      "type": "starlink_status",
      "title": "Starlink",
      "grid": { "col": 1, "row": 10, "w": 3, "h": 1 },
      "bind": { "source": "local", "sensor": "starlink", "refreshMs": 2000 }
    },
    {
      "id": "clock",
      "type": "clock",
      "grid": { "col": 4, "row": 10, "w": 2, "h": 1 },
      "props": { "tz": "Europe/London", "showDate": true }
    },
    {
      "id": "dispatch",
      "type": "dispatch_feed",
      "title": "Dispatch",
      "grid": { "col": 6, "row": 10, "w": 7, "h": 1 },
      "bind": { "source": "siphon", "sourceId": "dispatch:events", "refreshMs": 5000 }
    },
    {
      "id": "cabin",
      "type": "cabin_status",
      "title": "Cabin",
      "grid": { "col": 1, "row": 11, "w": 3, "h": 1 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 5000 }
    },
    {
      "id": "baro",
      "type": "baro_tile",
      "title": "Pressure",
      "grid": { "col": 4, "row": 11, "w": 3, "h": 1 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 5000 }
    },
    {
      "id": "wll-link",
      "type": "wll_link",
      "title": "WLL",
      "grid": { "col": 7, "row": 11, "w": 2, "h": 1 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 5000 }
    },
    {
      "id": "rain",
      "type": "weather_tile",
      "title": "Rain",
      "grid": { "col": 9, "row": 11, "w": 4, "h": 1 },
      "bind": { "source": "local", "sensor": "weather", "refreshMs": 5000 },
      "props": { "fields": ["rain", "rain24h", "solar", "uv"] }
    }
  ]
}
