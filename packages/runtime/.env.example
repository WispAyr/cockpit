# Outrider origin (where manifests are fetched from).
OUTRIDER_ORIGIN=https://outrider.wispayr.online

# Identity of this vehicle — uuid + HMAC secret as issued at provision time.
VEHICLE_ID=
DEVICE_KEY=

# Polling cadence for manifest check.
MANIFEST_POLL_MS=30000

# Local cache path (so the runtime can render on boot without network).
MANIFEST_CACHE_PATH=/var/lib/cockpit/manifest.json
